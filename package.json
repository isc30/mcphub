{
  "name": "@samanhappy/mcphub",
  "version": "dev",
  "description": "A hub server for mcp servers",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcphub": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "mcp_settings.json",
    "servers.json",
    "frontend/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm backend:build && pnpm frontend:build",
    "backend:build": "tsc",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/main.ts",
    "backend:dev": "node scripts/dev-backend.js",
    "backend:debug": "node scripts/dev-backend.js --inspect",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "release:check-notes": "node scripts/validate-release-notes.js",
    "frontend:dev": "cd frontend && vite",
    "frontend:build": "cd frontend && vite build",
    "frontend:preview": "cd frontend && vite preview",
    "dev": "concurrently \"pnpm backend:dev\" \"pnpm frontend:dev\"",
    "debug": "concurrently \"pnpm backend:debug\" \"pnpm frontend:dev\"",
    "prepublishOnly": "npm run build && node scripts/verify-dist.js"
  },
  "keywords": [
    "typescript",
    "server",
    "mcp",
    "model context protocol"
  ],
  "author": "",
  "license": "ISC",
